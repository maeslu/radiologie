---
import "../../styles/home-gerat.css";

interface Props {
  text?: string;
  image?: string;
  imageAlt?: string;
}

const { text = "", image = "", imageAlt = "Unser Gerät" } = Astro.props;
---

{(text || image) && (
  <section class="home-gerat">
    <div class="container home-gerat-inner">
      {image && (
        <div class="home-gerat-image">
          <img src={image} alt={imageAlt} />
        </div>
      )}
      <div class="home-gerat-content">
        {text && <p>{text}</p>}
      </div>
    </div>
  </section>
)}