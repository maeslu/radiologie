---
import "../../styles/home-hero.css";
interface Props {
  title?: string;
  lead?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  heroImage?: string;
}
const {
  title = "Erstklassige Behandlung",
  lead = "Modernste Diagnostik an zwei Standorten in Baden-Baden für Ihre Gesundheit. Zentral in der Innenstadt und mit Klinikanschluss.",
  primaryLabel = "Direkt Termin vereinbaren",
  primaryHref = "/kontakt",
  secondaryLabel = "Leistungen ansehen",
  secondaryHref = "/diagnostik",
  heroImage = "",
} = Astro.props;
---

<section class="home-hero">
  <div class="home-hero-bg" style={heroImage ? `--hero-bg: url('${heroImage}')` : ""} aria-hidden="true"></div>
  <div class="home-hero-inner container">
    <div class="home-hero-content">
      <h1>{title}</h1>
      <p class="home-hero-lead">{lead}</p>
      <div class="home-hero-actions">
        <a href={primaryHref} class="btn btn-primary btn-lg">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-hero-outline btn-lg">{secondaryLabel}</a>
      </div>
    </div>
  </div>
  <svg class="home-hero-wave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
    <path fill="currentColor" d="M0,64 C360,120 720,0 1080,48 C1260,72 1380,96 1440,80 L1440,120 L0,120 Z"></path>
  </svg>
</section>